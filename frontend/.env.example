# Копируй в frontend/.env (рядом с package.json), не коммить ключи.
#
# Подсказки адреса по умолчанию бесплатные: Photon (komoot.io, данные OSM), без ключей Яндекса.
# Ключи ниже — опционально, если нужны подсказки/геокодер Яндекса (в кабинете — тарифы и квоты).

# VITE_YANDEX_MAPS_API_KEY=
# VITE_YANDEX_SUGGEST_API_KEY=
