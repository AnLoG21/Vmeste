EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=vmesteofficialsupport@gmail.com
# 16 символов из https://myaccount.google.com/apppasswords (не обычный пароль Gmail!)
EMAIL_HOST_PASSWORD=
