# HTTPS через Let's Encrypt (прямой доступ к Selectel, без Cloudflare proxy).
{$DOMAIN}, www.{$DOMAIN} {
	@backend path /api/* /admin* /media/* /static/*
	handle @backend {
		reverse_proxy web:8000 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}
	handle {
		reverse_proxy frontend:80
	}
}
