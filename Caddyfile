# Замените example.ru на ваш домен в .env (переменная DOMAIN)
{$DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy web:8000
	}
	handle /admin* {
		reverse_proxy web:8000
	}
	handle /media/* {
		reverse_proxy web:8000
	}
	handle /static/* {
		reverse_proxy web:8000
	}
	handle {
		reverse_proxy frontend:80
	}
}

www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
